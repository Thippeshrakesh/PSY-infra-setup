# Local .terraform directory (contains binaries and plugins)
**/.terraform/*

# .tfstate files (Contains sensitive data and infrastructure metadata)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude any .tfvars files (Usually contain secrets or environment-specific data)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc